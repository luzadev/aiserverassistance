# ─── Telegram ────────────────────────────────────────────────────────────────
# Token del bot ottenuto da @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# ID Telegram autorizzati (numerici), separati da virgola.
# SOLO questi utenti possono parlare col bot ed eseguire comandi sui server.
# Non sai il tuo ID? Avvia il bot e scrivigli /whoami
ALLOWED_USER_IDS=178155678

# ─── Claude Code ─────────────────────────────────────────────────────────────
# Eseguibile della CLI di Claude Code (deve essere loggato sul server)
CLAUDE_BIN=claude
# Modello: opus (consigliato per sysadmin), sonnet, haiku
CLAUDE_MODEL=opus
# Timeout massimo per una singola richiesta a Claude (ms)
CLAUDE_TIMEOUT_MS=900000

# ─── Bridge approvazioni (solo localhost) ────────────────────────────────────
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8765
# Quanti ms attendere la tua approvazione su Telegram prima di considerare "negato"
APPROVAL_TIMEOUT_MS=240000

# ─── File ────────────────────────────────────────────────────────────────────
# Percorso del file con l'elenco dei server (vedi servers.example.json)
SERVERS_FILE=./servers.json
# Directory di lavoro per Claude (dove gira la CLI). Lasciala così di default.
WORKDIR=./workdir
